<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LockApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#00FFB0</item>
        <item name="colorPrimaryVariant">#00AA70</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="android:windowBackground">#0A0A0F</item>
        <item name="android:statusBarColor">#0A0A0F</item>
        <item name="android:navigationBarColor">#0A0A0F</item>
    </style>

    <style name="Theme.LockScreen" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#0A0A0F</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
